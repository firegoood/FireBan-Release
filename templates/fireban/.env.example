# Public gateway/listener.
# The Go gateway intentionally uses the historical UVICORN_* names.
UVICORN_HOST = "0.0.0.0"
UVICORN_PORT = 8000
# FIREBAN_GATEWAY_ADDR = ":8000"
# Legacy fallback: REBECCA_GATEWAY_ADDR

# Gateway TLS.
# UVICORN_SSL_CERTFILE = "/var/lib/fireban/certs/example.com/fullchain.pem"
# UVICORN_SSL_KEYFILE = "/var/lib/fireban/certs/example.com/key.pem"
# UVICORN_SSL_CA_TYPE = "public"

# Database.
# SQLALCHEMY_DATABASE_URL = "sqlite:///db.sqlite3"

# Binary/install metadata.
# FIREBAN_INSTALL_MODE = "binary"
# FIREBAN_SCRIPT_BIN = "/usr/local/bin/fireban"
# FIREBAN_APP_DIR = "/opt/fireban"
# FIREBAN_DATA_DIR = "/var/lib/fireban"
# FIREBAN_SERVICE_NAME = "fireban"
# Legacy fallbacks: REBECCA_INSTALL_MODE, REBECCA_SCRIPT_BIN, REBECCA_APP_DIR, REBECCA_DATA_DIR, REBECCA_SERVICE_NAME

# GitHub access for private FireBan/FireNode repositories and dev manifest checks.
# FIREBAN_GITHUB_TOKEN = ""

# Initial admin bootstrap.

# Node operations and user lifecycle jobs.
# FIREBAN_NODE_OPERATIONS_POLL_INTERVAL = "15s"
# FIREBAN_NODE_USAGE_COLLECTION_INTERVAL = "30s"
# FIREBAN_NODE_USAGE_COLLECTION_LIMIT = 0
# FIREBAN_USER_LIFECYCLE_INTERVAL = "10s"
# FIREBAN_USER_LIFECYCLE_BATCH_SIZE = 500
# FIREBAN_USER_USAGE_RESET_INTERVAL = "1h"
# FIREBAN_USER_USAGE_RESET_BATCH_SIZE = 500
# FIREBAN_PAY_AS_GO_SETTLEMENT_INTERVAL = "1h"
# FIREBAN_PAY_AS_GO_SETTLEMENT_BATCH_SIZE = 500
# FIREBAN_USER_AUTODELETE_INTERVAL = "1h"
# FIREBAN_USER_AUTODELETE_BATCH_SIZE = 500
# USERS_AUTODELETE_DAYS = -1
# USER_AUTODELETE_INCLUDE_LIMITED_ACCOUNTS = false

# API behavior.
# JWT_ACCESS_TOKEN_EXPIRE_MINUTES = 1440
# USERS_LIST_TIMEOUT_SECONDS = 0

# Settings, templates, certificates, and backup roots.
# FIREBAN_CERT_BASE = "/var/lib/fireban/certs"
# FIREBAN_CONFIG_DIR = "/etc/fireban"
